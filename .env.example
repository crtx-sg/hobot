# LLM Provider API Keys
GEMINI_API_KEY=your-gemini-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# HuggingFace token — required for gated models (MedGemma)
# Accept terms at https://huggingface.co/google/medgemma-4b-it then set token
HF_TOKEN=your-hf-token

# API Authentication — comma-separated client_id:key pairs
# All endpoints except /health require Authorization: Bearer <key>
API_KEYS=tg-bot:change-me-tg,webchat:change-me-web

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TG_BOT_API_KEY=change-me-tg

# Radiology (Orthanc) credentials
ORTHANC_USER=orthanc
ORTHANC_PASS=orthanc

# Session & confirmation tuning (optional)
# SESSION_TTL_HOURS=24
# CONFIRMATION_TTL_SECONDS=300
# MAX_MESSAGE_LENGTH=10000
